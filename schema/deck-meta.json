{
  "$id": "https://medchem-flashcards/schema/deck-meta-1.0.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Metadata for a deck. Card membership is derived from files on disk.",
  "properties": {
    "description": {
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "title": "Id",
      "type": "string"
    },
    "level": {
      "default": "core",
      "enum": [
        "intro",
        "core",
        "advanced"
      ],
      "title": "Level",
      "type": "string"
    },
    "order": {
      "default": 0,
      "title": "Order",
      "type": "integer"
    },
    "prerequisites": {
      "items": {
        "minLength": 1,
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "type": "string"
      },
      "title": "Prerequisites",
      "type": "array"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "description"
  ],
  "title": "DeckMeta",
  "type": "object"
}
